{
  "name": "nextjs-proxy",
  "version": "2.3.1",
  "description": "Universal, secure proxy for Next.js. Centralize, audit, and control all external API calls from a single entry point.",
  "homepage": "https://next-proxy-web.vercel.app",
  "author": "Haroldy Arturo Pérez Rodríguez <haroldyarturo@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcademan21/nextjs-proxy.git"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --out-dir dist --sourcemap",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm run typecheck",
    "test": "jest",
    "lint": "eslint ."
  },
  "keywords": [
    "next",
    "nextjs",
    "nextjs middleware",
    "next proxy",
    "proxy",
    "api",
    "cors",
    "security",
    "logging",
    "rate-limit",
    "transform",
    "gateway"
  ],
  "peerDependencies": {
    "next": ">=13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.0",
    "@types/react": "^19.2.17",
    "eslint": "^10.4.1",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.4.1",
    "next": "^15.5.19",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "ts-jest": "^29.4.1",
    "tsup": "^8.5.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.60.1"
  },
  "sideEffects": false
}
